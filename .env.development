# Variables for DEVELOPMENT Environment. <Last updated: 2025-01-15>
# Default config file: .env

################################
#     Environment Settings     #
################################

# Logs errors to stderr instead of throwing exceptions
TS_NODE_LOG_ERROR=false

# Node running environment
NODE_ENV=development

# Enable debug logging
NODE_DEBUG=true

# App environment name
APP_ENV=development

# App's running port
PORT=8888
