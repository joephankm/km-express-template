# Base Variables for All Environments. <Last updated: 2025-03-02>
# This env file contains definitions for all variables and will be used in all environments.
# It will take PRODUCTION values by default for environment variables.

# Variables Overwriting / Priority (dotenv flow stadard):
# yarn start: .env.development.local, .env.development, .env.local, .env
# yarn build: .env.production.local, .env.production, .env.local, .env
# yarn test: .env.test.local, .env.test, .env (note .env.local is missing)
# See: https://github.com/kerimdzhanov/dotenv-flow/blob/master/README.md#variables-overwritingpriority

################################
#     Environment Settings     #
################################

# Logs errors to stderr instead of throwing exceptions
TS_NODE_LOG_ERROR=true   # [BOOLEAN]

# Node running environment
NODE_ENV=production      # (ENUM<"development" | "production">)

# Enable debug logging
NODE_DEBUG=              # [BOOLEAN]

# App environment name
APP_ENV=                 # [STRING]

# App's running port
PORT=443                 # (NUMBER)


################################
#        App Variables         #
################################
