{
  "name": "km-express-template",
  "packageManager": "yarn@4.6.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "yarn env:local -- nodemon src/app.ts",
    "build": "tsc",
    "server": "yarn env:server -- node ./dist/app.js",
    "env:local": "dotenv -v NODE_PATH=./src -e \".env.${APP_ENV:-\"development\"}\" -e .env",
    "env:server": "dotenv -v NODE_PATH=./dist -e \".env.${APP_ENV:-\"development\"}\" -e .env",
    "predev": "yarn install",
    "prerun": "yarn install && yarn build",
    "prerun:production": "APP_ENV=production yarn prerun",
    "server:production": "APP_ENV=production yarn server",
    "prettier": "prettier --check --debug-check './src/**/*.{ts,js}' './**/*.{mjs,json}'",
    "prettier:fix": "prettier --write './src/**/*.{ts,js}' './**/*.{mjs,json}'",
    "lint": "yarn dlx eslint ./src && tsc --noEmit",
    "postinstall": "node .husky/install.mjs"
  },
  "dependencies": {
    "dotenv-cli": "^8.0.0",
    "express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
